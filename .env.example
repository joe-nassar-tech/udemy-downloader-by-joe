# Copy this file to .env. These values are safe pretend examples.

# Your private login tickets. Do not upload these files.
COOKIES_PATH=cookies.txt
COOKIES_JSON_PATH=cookies.json

# Keep empty unless a provider gives you lawful authorization.
WIDEVINE_KEY=your_copied_key_here

# Where finished course files go.
OUTPUT_DIR=courses

# Start small. Bigger numbers can make your internet tired.
CONCURRENT_DOWNLOADS=2

# Caption language. Example: en_US
SUBTITLE_LANG=en_US

# Names of helper programs beside main.py.
# e.g: N_M3U8DL_RE_PATH=C:/Users/deskuser/desktop/udemy-downloader-by-joe/n_m3u8dl-re.exen_m3u8dl-re.exe
N_M3U8DL_RE_PATH=n_m3u8dl-re.exe
# e.g: SHAKA_PACKAGER_PATH=C:/Users/deskuser/desktop/udemy-downloader-by-joe/shaka-packager.exe
SHAKA_PACKAGER_PATH=

# Optional pretend course link. You may leave this empty.
COURSE_LINK=https://www.udemy.com/course/example-course/
